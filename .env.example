# birds.garden backend - szablon zmiennych srodowiskowych
# Skopiuj do .env i uzupelnij wartosci. .env jest w .gitignore (sekrety).

# --- Anthropic API (generowanie tresci / story cards) ---
ANTHROPIC_API_KEY=

# --- Zdjecia / cropy ptakow ---
PHOTOS_DIR=/opt/bird-api/photos
PHOTOS_BASE_URL=https://birds.garden/photos

# --- Usluga detekcji (bird-yolo) ---
YOLO_HOST=127.0.0.1
YOLO_PORT=8002

# Model DETEKCJI. Produkcja: wlasny dotrenowany model (nie COCO yolov8n.pt).
YOLO_MODEL=/opt/bird-api/models/bird_v0.pt
# Klasy do wykrywania (przecinek). Nasz model ma 1 klase: bird.
YOLO_TARGET_CLASSES=bird
# Prog pewnosci detekcji (0-1).
YOLO_MIN_CONFIDENCE=0.35

# --- Klasyfikator gatunku ---
# Model klasyfikacji (yolov8n-cls). Pusto = pipeline dziala bez gatunku.
SPECIES_MODEL=/opt/bird-api/models/species.pt
# Prog pewnosci gatunku (0-1).
SPECIES_MIN_CONFIDENCE=
